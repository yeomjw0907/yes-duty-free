# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration (로컬: localhost, Vercel: https://yes-duty-free.vercel.app)
VITE_APP_URL=http://localhost:3001
VITE_APP_NAME=Yes Duty Free

# Environment
NODE_ENV=development

# PortOne (Server-side only: Supabase Edge Function secrets)
# - 아래 값들은 로컬 .env.local이 아니라 Supabase Functions secrets / Vercel env 등에 저장하세요.
# PORTONE_KEY=your-portone-key
# PORTONE_SECRET=your-portone-secret
# PORTONE_ENV=sandbox
# PORTONE_WEBHOOK_SECRET=your-portone-webhook-secret
